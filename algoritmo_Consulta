// STATE
// ═══════════════════════════════════════════════════════════════
let state = {
  step:'specialty', specialty:null, procedure:null,
  flags:{p1:[],p2:[],p3:[]},
  mcdt:new Set(),
  queue:[],
  allAnswers:{},
  history:[]
};

// ═══════════════════════════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════════════════════════
const riskLabel = r => ['','Muito Baixo','Baixo','Intermédio','Elevado','Muito Elevado'][r]||'?';
const riskMace  = r => ['','< 0,5%','0,5–1%','1–5%','> 5%','> 10%'][r]||'?';

function stepDots(current){
  const steps = ['Especialidade','Procedimento','Classificação','Avaliação Clínica','Relatório'];
  return `<div class="step-dots">${steps.map((s,i)=>{
    const n=i+1, cls=n===current?'active':n<current?'done':'';
    return `<div class="step-dot ${cls}"><div class="dot">${n<current?'✓':n}</div><div class="dot-label">${s}</div></div>${i<steps.length-1?`<div class="dot-line ${n<current?'done-line':''}"></div>`:''}`
  }).join('')}</div>`;
}

function findQuestion(id){for(const s of SYSTEMS){const q=s.questions.find(q=>q.id===id);if(q)return q;}return null;}
function findSystem(qid){return SYSTEMS.find(s=>s.questions.some(q=>q.id===qid))||SYSTEMS[0];}
function addFlag(level,text,ref){if(!state.flags[level].some(f=>f.text===text))state.flags[level].push({text,ref:ref||''});}
function cloneFlags(){return{p1:[...state.flags.p1],p2:[...state.flags.p2],p3:[...state.flags.p3]};}

function countAnswered(){return Object.keys(state.allAnswers).length;}
function countTotal(){return SYSTEMS.reduce((a,s)=>a+s.questions.length,0);}

// ═══════════════════════════════════════════════════════════════
// NAVIGATION
// ═══════════════════════════════════════════════════════════════
function selectSpecialty(id){
  state.history.push({step:state.step});
  state.specialty=id; state.step='procedure'; render();
}
function selectProcedure(id){
  state.history.push({step:state.step});
  state.procedure=PROCEDURES.find(p=>p.id===id); state.step='level3'; render();
}
function goBack(){
  if(state.step==='procedure')state.step='specialty';
  else if(state.step==='level3')state.step='procedure';
  render();
}
function goBackClinical(){
  if(state.history.length>0){
    const prev=state.history.pop();
    if(prev.fullState){
      const fs=prev.fullState;
      state.step=fs.step; state.queue=[...fs.queue];
      state.flags=cloneFlagsFrom(fs.flags); state.mcdt=new Set(fs.mcdt);
      state.allAnswers={...fs.allAnswers};
    } else { state.step=prev.step||'specialty'; }
    render();
  }
}
function cloneFlagsFrom(f){return{p1:[...f.p1],p2:[...f.p2],p3:[...f.p3]};}

function continueToLevel4(){
  state.history.push({step:state.step});
  const p=state.procedure;
  if(p.mandatoryConsult) addFlag('p2','Consulta obrigatória pelo tipo de procedimento','Protocolo ULS');
  if(p.diffAirway===true) addFlag('p2','Via Aérea Difícil prevista pelo procedimento','ESAIC 2023');
  if(p.risk===4) addFlag('p2','Cirurgia de Risco Elevado (MACE 30d > 5%)','ESAIC 2023');
  if(p.risk===5) addFlag('p1','Cirurgia de Risco Muito Elevado (MACE 30d > 10%) — consulta obrigatória','ESAIC 2023');
  if(p.bloodLoss>=500) state.mcdt.add('cbc');
  if(p.bloodLoss>=1000){state.mcdt.add('coag');state.mcdt.add('grupo');}
  if(p.ecg===true) state.mcdt.add('ecg');
  if(p.cbc===true) state.mcdt.add('cbc');
  if(p.coag===true) state.mcdt.add('coag');
  if(p.cxr===true) state.mcdt.add('cxr');
  if(p.pfr===true) state.mcdt.add('pfr');
  if(p.echo===true) state.mcdt.add('echo');
  if(p.biochem==='full'||p.biochem==='full+hba1c') state.mcdt.add('biochem_full');
  else if(p.biochem==='basic') state.mcdt.add('biochem_basic');
  state.queue=SYSTEMS.map(s=>s.questions[0].id);
  state.step='clinical'; render();
}

function earlyNoConsult(){
  state.flags={p1:[],p2:[],p3:[]}; state.mcdt=new Set(); state.queue=[];
  state.step='report'; render();
}

function answerQuestion(qid, answer){
  const q=findQuestion(qid); if(!q){state.queue.shift();render();return;}
  // Save history snapshot for back
  state.history.push({fullState:{
    step:state.step, queue:[...state.queue],
    flags:cloneFlags(), mcdt:new Set(state.mcdt), allAnswers:{...state.allAnswers}
  }});
  state.allAnswers[qid]=answer;
  const outcome=answer==='sim'?q.yes:q.no;
  if(outcome){
    (outcome.flags||[]).forEach(f=>addFlag(f.level,f.text,f.ref));
    (outcome.mcdt||[]).forEach(m=>state.mcdt.add(m));
  }
  state.queue.shift();
  if(outcome&&outcome.follow&&outcome.follow.length>0)
    state.queue=[...outcome.follow.filter(id=>!state.allAnswers[id]),...state.queue];
  // Remove already-answered questions from queue
  state.queue=state.queue.filter(id=>!state.allAnswers[id]);
  render();
}

function restart(){
  state={step:'specialty',specialty:null,procedure:null,flags:{p1:[],p2:[],p3:[]},mcdt:new Set(),queue:[],allAnswers:{},history:[]};
  render();
}

// ═══════════════════════════════════════════════════════════════
// MCDT BUILDER
// ═══════════════════════════════════════════════════════════════
function buildMcdtList(){
  const p=state.procedure; const ans=state.allAnswers;
  const list=new Set();
  const af=[...state.flags.p1,...state.flags.p2,...state.flags.p3].map(f=>f.text.toLowerCase());
  const has=(...t)=>t.some(x=>af.some(f=>f.includes(x)));
  const a=(q,v)=>ans[q]===v;

  // From procedure
  if(state.mcdt.has('ecg')) list.add('ECG de 12 Derivações');
  if(state.mcdt.has('cbc')) list.add('Hemograma Completo');
  if(state.mcdt.has('coag')) list.add('Coagulação (TP/INR, APTT, Fibrinogénio)');
  if(state.mcdt.has('cxr')) list.add('Radiografia do Tórax (PA)');
  if(state.mcdt.has('pfr')) list.add('Provas de Função Respiratória (Espirometria ± DLCO)');
  if(state.mcdt.has('echo')) list.add('Ecocardiograma Transtorácico');
  if(state.mcdt.has('biochem_full')) list.add('Bioquímica Completa (glicose, creatinina, Na, K, ureia, ALT, AST, bilirrubina, albumina)');
  else if(state.mcdt.has('biochem_basic')) list.add('Bioquímica Básica (glicose, creatinina, ionograma)');
  if(state.mcdt.has('grupo')) list.add('Grupo Sanguíneo + Pesquisa Anticorpos Irregulares + Reserva de Concentrados Eritrocitários');

  // ECG
  if(has('cardiopatia isquémica','insuficiência cardíaca','hta','fa/flutter','arritmia','estenose aórtica','valvulopatia','pacemaker','cdi','dispositivo cardíaco','bloqueio av','síncope','sca','eam','doença arterial','capacidade funcional < 4 met','dap sintomática','diabetes') || p.risk>=3)
    list.add('ECG de 12 Derivações');

  // CBC
  if(has('anemia','trombocitopenia','coagulopatia','drc','cirrose','diálise','transplante renal') || p.risk>=4 || p.bloodLoss>=500)
    list.add('Hemograma Completo');

  // Biochem
  if(has('cirrose','hepatopatia','drc','diálise','transplante renal') || p.risk>=5)
    list.add('Bioquímica Completa (glicose, creatinina, Na, K, ureia, ALT, AST, bilirrubina, albumina)');
  else if(has('hta','diabetes','drc moderada','cardiopatia') || p.risk>=3 || p.bloodLoss>=500)
    list.add('Bioquímica Básica (glicose, creatinina, ionograma)');

  // HbA1c
  if(a('q_dm','sim')||a('q_dm_insulina','sim')||a('q_dm_hba1c','sim')||state.mcdt.has('hba1c'))
    list.add('HbA1c (Hemoglobina A1c)');

  // Coag
  if(has('anticoagulação','coagulopatia','cirrose','trombocitopenia') || p.bloodLoss>=1000)
    list.add('Coagulação (TP/INR, APTT, Fibrinogénio)');

  // Chest X-ray
  if(has('doença pulmonar','dpoc','fibrose','hipertensão pulmonar','insuficiência cardíaca descompensada') || p.risk>=5)
    list.add('Radiografia do Tórax (PA)');

  // PFR
  if(has('dpoc','asma','fibrose pulmonar','doença pulmonar intersticial','hipertensão pulmonar')||state.mcdt.has('pfr'))
    list.add('Provas de Função Respiratória (Espirometria ± DLCO)');

  // Echo
  if(has('insuficiência cardíaca','estenose aórtica','valvulopatia','hipertensão pulmonar','feve','obesidade mórbida')||state.mcdt.has('echo'))
    list.add('Ecocardiograma Transtorácico');

  // BNP
  if(has('insuficiência cardíaca','diálise','drc terminal')||state.mcdt.has('bnp'))
    list.add('BNP / NT-proBNP');

  // Gasimetria
  if(has('dpoc grave','hipertensão pulmonar','fibrose pulmonar','doença pulmonar intersticial')||state.mcdt.has('gasimetria'))
    list.add('Gasimetria Arterial');

  // Ferro
  if(a('q_anemia','sim')||a('q_anemia_mod','sim')||a('q_anemia_grave','sim')||has('anemia'))
    list.add('Perfil de Ferro (ferro sérico, ferritina, TIBC) + Vitamina B12 + Ácido Fólico');

  // TSH
  if(has('tiroideopatia')||a('q_tiroide','sim')||p.note.toLowerCase().includes('tsh'))
    list.add('TSH');

  // Grupo sangue
  if(p.bloodLoss>=1000||p.risk>=5)
    list.add('Grupo Sanguíneo + Pesquisa Anticorpos Irregulares + Reserva de Concentrados Eritrocitários');
  else if(p.bloodLoss>=500)
    list.add('Grupo Sanguíneo + Pesquisa de Anticorpos Irregulares');

  // β-hCG
  if(p.sp==='GIN')
    list.add('Teste de Gravidez (β-hCG) — se mulher em idade fértil');

  return Array.from(list);
}

// ═══════════════════════════════════════════════════════════════
// RENDER
// ═══════════════════════════════════════════════════════════════
const app=document.getElementById('app');

function render(){
  if(state.step==='specialty')renderSpecialty();
  else if(state.step==='procedure')renderProcedure();
  else if(state.step==='level3')renderLevel3();
  else if(state.step==='clinical'){
    if(state.queue.length===0){state.step='report';render();}
    else renderClinical();
  }
  else if(state.step==='report')renderReport();
}

function renderSpecialty(){
  const sp=SPECIALTIES.find(s=>s.id===state.specialty);
  app.innerHTML=`
  <div class="header">
    <div class="header-title">
      <span class="header-icon">🏥</span>
      <div><div class="header-main">Referenciação Pré-operatória — Consulta de Anestesiologia</div>
      <div class="header-sub">ULS · Algoritmo Institucional · ESAIC 2023 · SPA · Protocolos Internos</div></div>
    </div>
  </div>
  <div class="main">
    <div class="step-indicator">${stepDots(1)}</div>
    <div class="card">
      <div class="card-title">Passo 1 — Especialidade Cirúrgica</div>
      <div class="card-sub">Selecione a especialidade do médico referenciador</div>
      <div class="specialty-grid">
        ${SPECIALTIES.map(s=>`<button class="specialty-btn" onclick="selectSpecialty('${s.id}')">
          <span class="spec-icon">${s.icon}</span><span class="spec-name">${s.name}</span>
        </button>`).join('')}
      </div>
    </div>
  </div>`;
}

function renderProcedure(){
  const sp=SPECIALTIES.find(s=>s.id===state.specialty);
  const procs=PROCEDURES.filter(p=>p.sp===state.specialty);
  app.innerHTML=`
  <div class="header">
    <div class="header-title">
      <span class="header-icon">${sp.icon}</span>
      <div><div class="header-main">${sp.name}</div>
      <div class="header-sub">Selecione o procedimento previsto</div></div>
    </div>
    <button class="back-btn" onclick="goBack()">← Voltar</button>
  </div>
  <div class="main">
    <div class="step-indicator">${stepDots(2)}</div>
    <div class="card">
      <div class="card-title">Passo 2 — Procedimento Cirúrgico</div>
      <div class="card-sub">Clique no procedimento planeado para este doente</div>
      <div class="proc-list">
        ${procs.map(p=>`<button class="proc-btn" onclick="selectProcedure('${p.id}')">
          <span class="proc-name">${p.name}</span>
          <span class="proc-risk risk-${p.risk}">${riskLabel(p.risk)}</span>
        </button>`).join('')}
      </div>
    </div>
  </div>`;
}

function renderLevel3(){
  const p=state.procedure;
  const sp=SPECIALTIES.find(s=>s.id===p.sp);
  const earlyExit=(p.anesthesia.toLowerCase().includes('tópica')&&p.risk===1&&!p.mandatoryConsult);
  app.innerHTML=`
  <div class="header">
    <div class="header-title">
      <span class="header-icon">${sp.icon}</span>
      <div><div class="header-main">${p.name}</div>
      <div class="header-sub">Nível 3 — Classificação automática do procedimento</div></div>
    </div>
    <button class="back-btn" onclick="goBack()">← Voltar</button>
  </div>
  <div class="main">
    <div class="step-indicator">${stepDots(3)}</div>
    <div class="card">
      <div class="card-title">Perfil do Procedimento</div>
      <table class="proc-table">
        <tr><td class="pt-label">Anestesia habitual</td><td>${p.anesthesia}</td></tr>
        <tr><td class="pt-label">Risco cirúrgico</td><td><span class="badge risk-${p.risk}">${riskLabel(p.risk)} — MACE a 30d: ${riskMace(p.risk)}</span></td></tr>
        <tr><td class="pt-label">Perda hemática esperada</td><td>${p.bloodLoss===0?'Mínima (<200 mL)':p.bloodLoss>=1000?`Major (≈ ${p.bloodLoss} mL)`:p.bloodLoss>=500?`Significativa (≈ ${p.bloodLoss} mL)`:`Baixa (≈ ${p.bloodLoss} mL)`}</td></tr>
        <tr><td class="pt-label">Regime</td><td>${p.amb===true?'✅ Ambulatório possível':p.amb===false?'❌ Internamento necessário':'⚠️ Condicional'}</td></tr>
        <tr><td class="pt-label">Via Aérea Difícil</td><td>${p.diffAirway===true?'⚠️ Prevista pelo procedimento':p.diffAirway==='cond'?'⚠️ Condicional — avaliar clinicamente':'Não prevista pelo procedimento'}</td></tr>
        ${p.note?`<tr><td class="pt-label">Nota</td><td>${p.note}</td></tr>`:''}
      </table>
      ${earlyExit?`
        <div class="early-exit">
          <div class="exit-icon">✅</div>
          <div><div class="exit-title">SAÍDA ANTECIPADA — Consulta provavelmente NÃO necessária</div>
          <div class="exit-sub">Procedimento de muito baixo risco sob anestesia tópica. Em doente ASA I-II sem comorbilidades, não é necessária avaliação pré-anestésica. Se o doente tiver comorbilidades relevantes, prosseguir para avaliação clínica.</div></div>
        </div>
        <div class="level3-btns">
          <button class="btn-secondary" onclick="continueToLevel4()">Doente com comorbilidades — Continuar avaliação</button>
          <button class="btn-primary btn-green" onclick="earlyNoConsult()">Sem comorbilidades — Confirmar: Sem Consulta</button>
        </div>
      `:`
        ${(p.mandatoryConsult||p.risk>=4)?`<div class="flags-preview"><div class="fp-title">🔎 Critérios identificados automaticamente:</div>
          ${p.mandatoryConsult?`<div class="fp-flag fp-p2">⚑ Consulta obrigatória pelo tipo de procedimento</div>`:''}
          ${p.risk>=5?`<div class="fp-flag fp-p1">⚑ Cirurgia de Risco Muito Elevado (MACE > 10%)</div>`:''}
          ${p.risk===4?`<div class="fp-flag fp-p2">⚑ Cirurgia de Risco Elevado (MACE > 5%)</div>`:''}
        </div>`:''}
        <div class="level3-message">
          ${p.mandatoryConsult?'⚠️ Este procedimento requer Consulta de Anestesiologia. Prossiga para identificar prioridade e MCDT.':'Prossiga para avaliação clínica do doente (Nível 4).'}
        </div>
        <div class="level3-btns">
          <button class="btn-primary" onclick="continueToLevel4()">Continuar → Avaliação Clínica do Doente</button>
        </div>
      `}
    </div>
  </div>`;
}

function renderClinical(){
  const qid=state.queue[0];
  const q=findQuestion(qid);
  if(!q){state.queue.shift();render();return;}
  const sys=findSystem(qid);
  const pct=Math.min(99,Math.round((countAnswered()/Math.max(countTotal(),1))*100));

  app.innerHTML=`
  <div class="header" style="background:${sys.color}">
    <div class="header-title">
      <span class="header-icon">${sys.icon}</span>
      <div><div class="header-main">${sys.title}</div>
      <div class="header-sub">${state.procedure.name}</div></div>
    </div>
    <button class="back-btn" onclick="goBackClinical()">← Voltar</button>
  </div>
  <div class="main main-clinical">
    <div class="progress-bar-wrap">
      <div class="progress-bar-fill" style="width:${pct}%"></div>
      <div class="progress-label">Avaliação Clínica — ${pct}% concluída · ${countAnswered()} perguntas respondidas</div>
    </div>
    <div class="clinical-layout">
      <div class="question-area">
        <div class="question-card">
          <div class="q-system-badge" style="background:${sys.color}">${sys.icon} ${sys.title}</div>
          <div class="q-text">${(q.text||'').replace(/\n/g,'<br>')}</div>
          ${q.hint?`<div class="q-hint">ℹ️ ${q.hint}</div>`:''}
          <div class="q-btns">
            <button class="btn-sim" onclick="answerQuestion('${qid}','sim')">✓ &nbsp;SIM</button>
            <button class="btn-nao" onclick="answerQuestion('${qid}','nao')">✗ &nbsp;NÃO</button>
          </div>
        </div>
        <div class="nav-hint">Responda SIM ou NÃO. O algoritmo adapta-se automaticamente às suas respostas.</div>
      </div>
      <div class="criteria-panel">
        <div class="cp-title">Critérios Identificados</div>
        ${renderCriteriaPanel()}
      </div>
    </div>
  </div>`;
}

function renderCriteriaPanel(){
  const {p1,p2,p3}=state.flags;
  if(!p1.length&&!p2.length&&!p3.length)return'<div class="cp-empty">Nenhum critério identificado ainda</div>';
  let h='';
  if(p1.length){h+='<div class="cp-section cp-p1">⚡ PRIORITÁRIA (P1)</div>';h+=p1.map(f=>`<div class="cp-item cp-item-p1">• ${f.text}</div>`).join('');}
  if(p2.length){h+='<div class="cp-section cp-p2">📋 NECESSÁRIA (P2)</div>';h+=p2.map(f=>`<div class="cp-item cp-item-p2">• ${f.text}</div>`).join('');}
  if(p3.length){h+='<div class="cp-section cp-p3">🔧 OTIMIZAÇÃO (P3)</div>';h+=p3.map(f=>`<div class="cp-item cp-item-p3">• ${f.text}</div>`).join('');}
  return h;
}

function renderReport(){
  const p=state.procedure;
  const sp=SPECIALTIES.find(s=>s.id===p.sp);
  const {p1,p2,p3}=state.flags;
  let decision,priority,decBg;
  if(p1.length>0){decision='CONSULTA DE ANESTESIOLOGIA NECESSÁRIA';priority='⚡ PRIORITÁRIA — P1 (≤ 5 dias úteis)';decBg='#C00000';}
  else if(p2.length>0||p.mandatoryConsult||p.risk>=4){decision='CONSULTA DE ANESTESIOLOGIA NECESSÁRIA';priority='📋 NORMAL — P2 (≤ 20 dias úteis)';decBg='#C05621';}
  else if(p3.length>0){decision='CONSULTA DE ANESTESIOLOGIA — OTIMIZAÇÃO';priority='🔧 P3 (prazo a definir caso a caso)';decBg='#7F6000';}
  else{decision='CONSULTA DE ANESTESIOLOGIA NÃO NECESSÁRIA';priority='✅ Prosseguir para cirurgia sem avaliação pré-anestésica';decBg='#276749';}
  const mcdtList=buildMcdtList();
  const dateStr=new Date().toLocaleDateString('pt-PT',{day:'2-digit',month:'2-digit',year:'numeric'});

  app.innerHTML=`
  <div class="header">
    <div class="header-title">
      <span class="header-icon">📋</span>
      <div><div class="header-main">Relatório de Referenciação Pré-operatória</div>
      <div class="header-sub">Emitido em ${dateStr} · ${sp.name} · ${p.name}</div></div>
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
      <button class="back-btn" onclick="goBackClinical()">← Rever</button>
      <button class="back-btn" onclick="window.print()" style="background:rgba(255,255,255,.25)">🖨️ Imprimir</button>
      <button class="back-btn" onclick="restart()" style="background:rgba(255,255,255,.25)">↺ Nova Avaliação</button>
    </div>
  </div>
  <div class="main" id="report-content">
    <div class="report-decision" style="background:${decBg};color:#fff">
      <div class="rd-main">${decision}</div>
      <div class="rd-priority">${priority}</div>
    </div>
    <div class="report-grid">
      <div class="report-section">
        <div class="rs-title">🔍 Procedimento e Risco Cirúrgico</div>
        <table class="report-table">
          <tr><td>Especialidade</td><td><strong>${sp.name}</strong></td></tr>
          <tr><td>Procedimento</td><td><strong>${p.name}</strong></td></tr>
          <tr><td>Risco Cirúrgico</td><td><span class="badge risk-${p.risk}">${riskLabel(p.risk)} (MACE 30d: ${riskMace(p.risk)})</span></td></tr>
          <tr><td>Tipo de Anestesia</td><td>${p.anesthesia}</td></tr>
          <tr><td>Perda Hemática Esperada</td><td>${p.bloodLoss===0?'Mínima':p.bloodLoss>=1000?`Major (≈${p.bloodLoss}mL)`:p.bloodLoss>=500?`Significativa (≈${p.bloodLoss}mL)`:`Baixa (≈${p.bloodLoss}mL)`}</td></tr>
          <tr><td>Consulta por Procedimento</td><td>${p.mandatoryConsult?'✅ Sim':'—'}</td></tr>
          ${p.note?`<tr><td>Nota</td><td>${p.note}</td></tr>`:''}
        </table>
      </div>
      <div class="report-section">
        <div class="rs-title">⚑ Motivos da Decisão</div>
        ${p1.length===0&&p2.length===0&&p3.length===0&&!p.mandatoryConsult&&p.risk<4?
          '<div class="rs-none">Nenhum critério clínico identificado. Doente sem patologia relevante identificada pela avaliação clínica.</div>':
          `${(p.mandatoryConsult||p.risk>=4)?`<div class="rs-flag rs-p2">📋 ${p.risk>=5?'Cirurgia de Risco Muito Elevado':p.risk===4?'Cirurgia de Risco Elevado':'Consulta obrigatória pelo procedimento'}</div>`:''}`+
          p1.map(f=>`<div class="rs-flag rs-p1">⚡ [P1] ${f.text}<div class="rs-ref">${f.ref}</div></div>`).join('')+
          p2.map(f=>`<div class="rs-flag rs-p2">📋 [P2] ${f.text}<div class="rs-ref">${f.ref}</div></div>`).join('')+
          p3.map(f=>`<div class="rs-flag rs-p3">🔧 [P3] ${f.text}<div class="rs-ref">${f.ref}</div></div>`).join('')
        }
      </div>
      <div class="report-section report-section-full">
        <div class="rs-title">🧪 Exames Complementares de Diagnóstico Recomendados</div>
        ${mcdtList.length===0?
          '<div class="rs-none">Nenhum exame complementar indicado (cirurgia de baixo risco, doente sem comorbilidades identificadas).</div>':
          `<div class="mcdt-grid">${mcdtList.map(m=>`<div class="mcdt-item">✓ ${m}</div>`).join('')}</div>`
        }
        <div class="mcdt-note">⚠️ MCDT resultam da combinação procedimento + risco cirúrgico + comorbilidades. Não solicitar por rotina exames não listados. Baseado na ESAIC 2023 e recomendações SPA.</div>
      </div>
      <div class="report-section report-section-full">
        <div class="rs-title">📚 Referências</div>
        <div class="refs">
          <div>• De Hert S, et al. ESAIC Guidelines: Pre-operative evaluation of adults undergoing elective non-cardiac surgery. Eur J Anaesthesiol 2023;40(1):13-103.</div>
          <div>• Halvorsen S, et al. ESC Guidelines on cardiovascular assessment and management for non-cardiac surgery. Eur Heart J 2022;43(39):3826-3924.</div>
          <div>• Sociedad Portuguesa de Anestesiologia (SPA). Recomendações para Avaliação Pré-Anestésica, 2022.</div>
          <div>• Muñoz M, et al. NATA recommendations for Patient Blood Management in surgical patients. Br J Anaesth 2017;119(5):819-838.</div>
          <div>• Protocolos Internos — Serviço de Anestesiologia ULS.</div>
        </div>
      </div>
    </div>
    <div class="report-footer">Gerado pelo CDSS de Referenciação Pré-operatória — ULS · ${dateStr} · Arquivar no processo clínico do doente.</div>
  </div>`;
}

// ═══════════════════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════════════════
render();
</script>
