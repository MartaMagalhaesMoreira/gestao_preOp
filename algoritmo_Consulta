<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CDSS — Referenciação Pré-operatória para Anestesiologia</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#F0F4F8;color:#1A202C;min-height:100vh}
#app{min-height:100vh;display:flex;flex-direction:column}

/* HEADER */
.header{background:#1B3A5C;color:#fff;padding:14px 20px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;print-color-adjust:exact;-webkit-print-color-adjust:exact}
.header-title{display:flex;align-items:center;gap:12px}
.header-icon{font-size:1.6rem}
.header-main{font-size:1rem;font-weight:700;letter-spacing:.01em}
.header-sub{font-size:.75rem;opacity:.75;margin-top:2px}
.back-btn{background:rgba(255,255,255,.2);border:1px solid rgba(255,255,255,.4);color:#fff;padding:6px 14px;border-radius:6px;cursor:pointer;font-size:.85rem;transition:.15s}
.back-btn:hover{background:rgba(255,255,255,.35)}

/* MAIN */
.main{flex:1;padding:20px;max-width:1100px;width:100%;margin:0 auto}
.main-clinical{max-width:1300px}

/* STEP DOTS */
.step-indicator{margin-bottom:20px}
.step-dots{display:flex;align-items:center;gap:0}
.step-dot{display:flex;flex-direction:column;align-items:center;gap:4px}
.dot{width:30px;height:30px;border-radius:50%;background:#CBD5E0;color:#4A5568;font-size:.75rem;font-weight:700;display:flex;align-items:center;justify-content:center}
.step-dot.active .dot{background:#1B3A5C;color:#fff}
.step-dot.done .dot{background:#2F855A;color:#fff}
.dot-label{font-size:.65rem;color:#718096;white-space:nowrap}
.dot-line{flex:1;height:2px;background:#CBD5E0;min-width:20px;margin:0 2px}
.done-line{background:#2F855A}

/* CARD */
.card{background:#fff;border-radius:12px;padding:24px;box-shadow:0 2px 8px rgba(0,0,0,.08);margin-bottom:16px}
.card-title{font-size:1.1rem;font-weight:700;color:#1B3A5C;margin-bottom:6px}
.card-sub{font-size:.85rem;color:#718096;margin-bottom:20px}

/* SPECIALTY GRID */
.specialty-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px}
.specialty-btn{background:#F7FAFC;border:2px solid #E2E8F0;border-radius:10px;padding:18px 12px;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:8px;transition:.2s;text-align:center}
.specialty-btn:hover{border-color:#1B3A5C;background:#EBF4FF;transform:translateY(-2px);box-shadow:0 4px 12px rgba(27,58,92,.15)}
.spec-icon{font-size:2rem}
.spec-name{font-size:.85rem;font-weight:600;color:#2D3748}

/* PROCEDURE LIST */
.proc-list{display:flex;flex-direction:column;gap:8px}
.proc-btn{background:#F7FAFC;border:1px solid #E2E8F0;border-radius:8px;padding:12px 16px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap:12px;transition:.15s;text-align:left}
.proc-btn:hover{border-color:#1B3A5C;background:#EBF4FF}
.proc-name{font-size:.9rem;font-weight:500;color:#2D3748}
.proc-risk{font-size:.75rem;font-weight:700;padding:3px 8px;border-radius:12px;white-space:nowrap}

/* RISK BADGES */
.risk-1{background:#C6F6D5;color:#22543D}
.risk-2{background:#BEE3F8;color:#2A4365}
.risk-3{background:#FEFCBF;color:#744210}
.risk-4{background:#FED7AA;color:#7B341E}
.risk-5{background:#FED7D7;color:#742A2A}
.badge{display:inline-block;padding:3px 8px;border-radius:12px;font-size:.75rem;font-weight:700}

/* PROCEDURE TABLE */
.proc-table{width:100%;border-collapse:collapse;margin:12px 0}
.proc-table tr{border-bottom:1px solid #E2E8F0}
.proc-table td{padding:10px;font-size:.88rem}
.pt-label{color:#718096;font-weight:600;width:220px}

/* LEVEL 3 */
.early-exit{background:#F0FFF4;border:2px solid #38A169;border-radius:10px;padding:16px;display:flex;align-items:flex-start;gap:12px;margin:16px 0}
.exit-icon{font-size:2rem}
.exit-title{font-size:1rem;font-weight:700;color:#22543D}
.exit-sub{font-size:.85rem;color:#2F4A3A;margin-top:4px}
.flags-preview{background:#FFFBEB;border:1px solid #F6E05E;border-radius:8px;padding:12px;margin:12px 0}
.fp-title{font-size:.8rem;font-weight:600;color:#744210;margin-bottom:8px}
.fp-flag{font-size:.85rem;padding:4px 0;color:#2D3748}
.fp-p1{color:#C53030;font-weight:600}
.fp-p2{color:#C05621}
.level3-message{background:#EBF4FF;border-left:4px solid #1B3A5C;padding:12px;border-radius:0 8px 8px 0;font-size:.9rem;color:#2A4365;margin:12px 0}
.level3-btns{display:flex;gap:12px;margin-top:16px;flex-wrap:wrap}
.btn-primary{background:#1B3A5C;color:#fff;border:none;padding:12px 24px;border-radius:8px;cursor:pointer;font-size:.9rem;font-weight:600;transition:.15s}
.btn-primary:hover{background:#2D5986}
.btn-secondary{background:#fff;color:#1B3A5C;border:2px solid #1B3A5C;padding:12px 24px;border-radius:8px;cursor:pointer;font-size:.9rem;font-weight:600;transition:.15s}
.btn-secondary:hover{background:#EBF4FF}
.btn-green{background:#2F855A}
.btn-green:hover{background:#276749}

/* CLINICAL LAYOUT */
.clinical-layout{display:grid;grid-template-columns:1fr 320px;gap:16px;align-items:start}
@media(max-width:800px){.clinical-layout{grid-template-columns:1fr}}

/* PROGRESS BAR */
.progress-bar-wrap{background:#E2E8F0;border-radius:99px;height:10px;margin-bottom:16px;position:relative;overflow:visible}
.progress-bar-fill{background:#1B3A5C;height:100%;border-radius:99px;transition:width .4s}
.progress-label{font-size:.75rem;color:#718096;margin-top:4px;text-align:center}

/* QUESTION CARD */
.question-card{background:#fff;border-radius:12px;padding:24px;box-shadow:0 2px 8px rgba(0,0,0,.08)}
.q-system-badge{display:inline-block;color:#fff;padding:4px 12px;border-radius:20px;font-size:.75rem;font-weight:700;margin-bottom:14px}
.q-text{font-size:1rem;font-weight:500;color:#1A202C;line-height:1.7;margin-bottom:14px;white-space:pre-wrap}
.q-hint{background:#EBF8FF;border-left:3px solid #63B3ED;padding:10px;border-radius:0 6px 6px 0;font-size:.82rem;color:#2C5282;margin-bottom:16px;line-height:1.5}
.q-btns{display:flex;gap:12px}
.btn-sim{flex:1;background:#2F855A;color:#fff;border:none;padding:14px;border-radius:8px;font-size:1rem;font-weight:700;cursor:pointer;letter-spacing:.05em;transition:.15s}
.btn-sim:hover{background:#276749;transform:translateY(-1px)}
.btn-nao{flex:1;background:#C53030;color:#fff;border:none;padding:14px;border-radius:8px;font-size:1rem;font-weight:700;cursor:pointer;letter-spacing:.05em;transition:.15s}
.btn-nao:hover{background:#9B2C2C;transform:translateY(-1px)}
.nav-hint{font-size:.75rem;color:#A0AEC0;text-align:center;margin-top:10px}

/* CRITERIA PANEL */
.criteria-panel{background:#fff;border-radius:12px;padding:16px;box-shadow:0 2px 8px rgba(0,0,0,.08);position:sticky;top:16px}
.cp-title{font-size:.85rem;font-weight:700;color:#1B3A5C;margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid #E2E8F0}
.cp-empty{font-size:.82rem;color:#A0AEC0;font-style:italic}
.cp-section{font-size:.7rem;font-weight:800;letter-spacing:.08em;margin:10px 0 4px;padding:3px 6px;border-radius:4px}
.cp-p1{background:#FFF5F5;color:#C53030}
.cp-p2{background:#FFFAF0;color:#C05621}
.cp-p3{background:#FFFFF0;color:#744210}
.cp-item{font-size:.78rem;padding:3px 0;line-height:1.5;color:#2D3748}
.cp-item-p1{color:#C53030;font-weight:500}
.cp-item-p2{color:#744210}
.cp-item-p3{color:#5F4408}

/* REPORT */
.report-decision{border-radius:10px;padding:18px 22px;margin-bottom:16px;text-align:center}
.rd-main{font-size:1.3rem;font-weight:800;letter-spacing:.03em}
.rd-priority{font-size:.9rem;margin-top:4px;font-weight:600;opacity:.9}
.report-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
@media(max-width:700px){.report-grid{grid-template-columns:1fr}}
.report-section{background:#fff;border-radius:10px;padding:18px;box-shadow:0 1px 4px rgba(0,0,0,.07)}
.report-section-full{grid-column:1/-1}
.rs-title{font-size:.85rem;font-weight:700;color:#1B3A5C;margin-bottom:12px;padding-bottom:6px;border-bottom:1px solid #E2E8F0}
.report-table{width:100%;border-collapse:collapse;font-size:.85rem}
.report-table tr{border-bottom:1px solid #EDF2F7}
.report-table td{padding:7px 4px}
.report-table td:first-child{color:#718096;width:48%;font-weight:500}
.rs-flag{border-radius:6px;padding:8px 10px;margin-bottom:8px;font-size:.83rem;line-height:1.5}
.rs-p1{background:#FFF5F5;border-left:3px solid #C53030;color:#742A2A}
.rs-p2{background:#FFFAF0;border-left:3px solid #ED8936;color:#744210}
.rs-p3{background:#FEFCE8;border-left:3px solid #ECC94B;color:#5F4408}
.rs-ref{font-size:.7rem;color:#A0AEC0;margin-top:2px}
.rs-none{font-size:.83rem;color:#718096;font-style:italic}
.mcdt-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:6px;margin-bottom:10px}
.mcdt-item{background:#F0FFF4;border:1px solid #9AE6B4;border-radius:6px;padding:8px 10px;font-size:.82rem;color:#22543D;font-weight:500}
.mcdt-note{font-size:.75rem;color:#718096;background:#F7FAFC;padding:8px;border-radius:6px;margin-top:4px}
.refs{font-size:.78rem;color:#4A5568;line-height:2}
.report-footer{text-align:center;font-size:.7rem;color:#A0AEC0;padding:12px;margin-top:8px}

/* PRINT */
@media print{
  .back-btn,.btn-primary,.btn-secondary,.btn-sim,.btn-nao,.btn-green{display:none!important}
  .header{background:#1B3A5C!important;-webkit-print-color-adjust:exact;print-color-adjust:exact}
  body{background:#fff}
}
</style>
</head>
